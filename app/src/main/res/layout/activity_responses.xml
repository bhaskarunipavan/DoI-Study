<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/grey_light">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorPrimary"
        app:titleTextColor="@color/white"
        app:title="All Responses"
        app:navigationIcon="?attr/homeAsUpIndicator"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:singleSelection="true">
            <com.google.android.material.chip.Chip android:id="@+id/chipAll"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="All" style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipDIC"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DIC" style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipEnterprise"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Enterprise" style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipAssociation"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Association" style="@style/Widget.MaterialComponents.Chip.Filter"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipStakeholder"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Stakeholder" style="@style/Widget.MaterialComponents.Chip.Filter"/>
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No responses yet.\nStart a questionnaire from the home screen."
        android:textColor="@color/grey_medium"
        android:textSize="14sp"
        android:textAlignment="center"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="12dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Export CSV"
            android:layout_marginRight="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSyncAll"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Sync All"/>
    </LinearLayout>
</LinearLayout>
