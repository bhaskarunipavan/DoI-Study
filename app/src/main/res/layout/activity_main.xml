<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/grey_light">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/colorPrimary"
        app:titleTextColor="@color/white"
        app:title="DIC Survey"
        app:subtitle="District Industrial Centre"
        app:subtitleTextColor="#BBDEFB"/>

    <!-- Sync status bar -->
    <LinearLayout
        android:id="@+id/syncBar"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@color/colorPrimaryDark"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvSyncStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#BBDEFB"
            android:textSize="12sp"
            android:text="Checking connection…"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSyncNow"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:text="Sync Now"
            android:textColor="@color/colorSecondary"
            android:textSize="11sp"
            android:minHeight="0dp"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Officer info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="2dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:text="👤"
                        android:textSize="28sp"
                        android:gravity="center"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginLeft="12dp">

                        <TextView
                            android:id="@+id/tvOfficerName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/grey_dark"
                            android:text="Officer Name"/>

                        <TextView
                            android:id="@+id/tvDistrictName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="@color/grey_medium"
                            android:text="District"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvTotalCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorPrimary"
                            android:gravity="center"
                            android:text="0"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="11sp"
                            android:textColor="@color/grey_medium"
                            android:text="Responses"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECT QUESTIONNAIRE TYPE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/grey_medium"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- DIC Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardDIC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/card_dic"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🏢" android:textSize="28sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="DoI / DIC Questionnaire" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/card_dic_border"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="District profile, industrial units, infrastructure" android:textSize="12sp"
                            android:textColor="@color/grey_medium" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="24sp" android:textColor="@color/card_dic_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Enterprise Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEnterprise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/card_enterprise"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🏭" android:textSize="28sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Industry / Enterprise Survey" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/card_enterprise_border"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Individual industry enterprise detailed survey" android:textSize="12sp"
                            android:textColor="@color/grey_medium" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="24sp" android:textColor="@color/card_enterprise_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Association Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardAssociation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/card_association"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🤝" android:textSize="28sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Industrial Association Survey" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/card_association_border"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Association and cluster survey" android:textSize="12sp"
                            android:textColor="@color/grey_medium" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="24sp" android:textColor="@color/card_association_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stakeholder Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStakeholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="12dp"
                android:foreground="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/card_stakeholder"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="48dp" android:layout_height="48dp"
                        android:text="🏛" android:textSize="28sp" android:gravity="center"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:layout_marginLeft="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Stakeholder Questionnaire" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/card_stakeholder_border"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Line departments, banks, skill institutions" android:textSize="12sp"
                            android:textColor="@color/grey_medium" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="24sp" android:textColor="@color/card_stakeholder_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- View Responses -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewResponses"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="View All Responses"
                android:layout_marginTop="8dp"
                app:strokeColor="@color/colorPrimary"
                android:textColor="@color/colorPrimary"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
